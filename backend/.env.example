NODE_ENV=development
PORT=4000
APP_ORIGINS=http://localhost:8080,http://localhost:3000
# URL publica do frontend (links nos e-mails, ex. resultado-completo). Deve coincidir com a porta do Vite em dev (8080).
FRONTEND_BASE_URL=http://localhost:8080

DATABASE_URL=mysql://nivel7:nivel7@127.0.0.1:3306/nivel7?sslaccept=accept_invalid_certs
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=change_me_access_secret_123456
JWT_REFRESH_SECRET=change_me_refresh_secret_123456
ADMIN_EMAIL=admin@nivel7.com
ADMIN_PASSWORD=change_me_admin_password

CAJUPAY_BASE_URL=https://api.cajupay.com.br
CAJUPAY_API_KEY=
CAJUPAY_API_SECRET=
# CPF ficticio valido (11 digitos) para consumer no PIX se a Caju exigir documento
CAJUPAY_DEFAULT_CONSUMER_DOCUMENT=00000000191

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
