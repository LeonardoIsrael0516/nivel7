          "Bloqueios de atracao",
          "Plano de 7 dias",
          "Primeira impressao social",
          "Simulacao de evolucao"
        ]
      }
    ]
  },
  "emailTemplates": {
    "deliveryInitial": {
      "subject": "Seu Raio-X de Atracao esta pronto",
      "body": "{nome}, seu diagnostico inicial foi concluido.\nSua nota parcial: {notaFinal}/10.\nSeu principal ponto de atencao: {insight}.\n\nPara ver seu relatorio completo e seu plano de melhoria, desbloqueie aqui:\n{linkDesbloqueio}"
    },
    "recoveryD1": {
      "subject": "Voce viu isso no seu resultado?",
